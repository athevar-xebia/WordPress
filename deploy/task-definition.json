{
  "family": "<+service.name>",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "<+serviceVariables.EXECUTION_ROLE_ARN>",
  "taskRoleArn": "<+serviceVariables.TASK_ROLE_ARN>",
  "containerDefinitions": [
    {
      "name": "wordpress",
      "image": "<+artifacts.primary.image>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "WORDPRESS_DB_HOST",
          "value": "<+variable.WORDPRESS_DB_HOST>"
        },
        {
          "name": "WORDPRESS_DB_NAME",
          "value": "<+variable.WORDPRESS_DB_NAME>"
        },
        {
          "name": "WORDPRESS_DB_USER",
          "value": "<+secrets.getValue(\"wordpress_db_user\")>"
        },
        {
          "name": "WORDPRESS_DB_PASSWORD",
          "value": "<+secrets.getValue(\"wordpress_db_password\")>"
        },
        {
          "name": "WORDPRESS_DEBUG",
          "value": "<+variable.WORDPRESS_DEBUG>"
        },
        {
          "name": "ENV_NAME",
          "value": "<+env.name>"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget --quiet --spider http://localhost/wp-login.php || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/wordpress-<+env.name>",
          "awslogs-region": "<+serviceVariables.AWS_REGION>",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "cpu": 1024,
      "memory": 2048
    }
  ]
}
