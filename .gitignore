# Generated at runtime by the WordPress entrypoint from WORDPRESS_* env vars.
wp-config.php

# Local debug logs (WP_DEBUG_LOG writes here).
wp-content/debug.log
*.log

# User uploads, caches, and upgrade scratch — never belong in source control.
wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/backup-db/

# Local env overrides.
.env
.env.local

# OS junk.
.DS_Store
Thumbs.db

# Editor / IDE.
.idea/
.vscode/
*.swp
*.swo

# Node (used by some build tooling under wp-content).
node_modules/
