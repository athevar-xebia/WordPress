# --- Database ---

# Name of the database created by MariaDB on first boot and used by WordPress.
DB_NAME=wordpress

# Application database user. WordPress connects as this user; it is not root.
DB_USER=wordpress

# Password for DB_USER. Replace before pushing or deploying.
DB_PASSWORD=change_me

# MariaDB root password — used only for administrative tasks, not by WordPress.
DB_ROOT_PASSWORD=change_me_root

# --- WordPress ---

# Toggles WP_DEBUG in the generated wp-config.php. Accepts: true, false, 1, 0.
WORDPRESS_DEBUG=false
